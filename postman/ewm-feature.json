        {
          "name": "Создать событие",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Событие создано\", function () {",
                  "    pm.response.to.have.status(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('eventId', jsonData.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var futureDate = new Date();",
                  "futureDate.setDate(futureDate.getDate() + 3);",
                  "var formatted = futureDate.getFullYear() + '-' + ",
                  "    String(futureDate.getMonth() + 1).padStart(2, '0') + '-' + ",
                  "    String(futureDate.getDate()).padStart(2, '0') + ' ' +",
                  "    String(futureDate.getHours()).padStart(2, '0') + ':' +",
                  "    String(futureDate.getMinutes()).padStart(2, '0') + ':' +",
                  "    String(futureDate.getSeconds()).padStart(2, '0');",
                  "pm.collectionVariables.set('eventDate', formatted);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"annotation\": \"Тестовое событие для проверки комментариев. Минимум 20 символов.\",\n  \"category\": {{categoryId}},\n  \"description\": \"Полное описание тестового события. Здесь должно быть минимум 20 символов для валидации.\",\n  \"eventDate\": \"{{eventDate}}\",\n  \"location\": {\n    \"lat\": 55.754167,\n    \"lon\": 37.62\n  },\n  \"paid\": false,\n  \"participantLimit\": 0,\n  \"requestModeration\": false,\n  \"title\": \"Тестовое событие\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "events"]
            }
          },
          "response": []
        },
        {
          "name": "Опубликовать событие (админ)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Событие опубликовано\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.state).to.eql('PUBLISHED');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stateAction\": \"PUBLISH_EVENT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/events/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "events", "{{eventId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Private: Комментарии",
      "item": [
        {
          "name": "Создать комментарий",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Комментарий содержит все поля модели\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('text');",
                  "    pm.expect(jsonData).to.have.property('userId');",
                  "    pm.expect(jsonData).to.have.property('eventId');",
                  "    pm.expect(jsonData).to.have.property('createdOn');",
                  "    pm.expect(jsonData).to.have.property('editedOn');",
                  "});",
                  "pm.test(\"Комментарий не помечен как отредактированный\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.editedOn).to.be.null;",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('commentId', jsonData.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Ewm-User-Id",
                "value": "{{userId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Отличное событие! Обязательно приду.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "comments"]
            }
