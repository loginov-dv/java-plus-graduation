        {
          "name": "Редактировать комментарий",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Текст обновлен\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.text).to.include('ОБНОВЛЕНО');",
                  "});",
                  "pm.test(\"Поле editedOn заполнено\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.editedOn).to.not.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "setTimeout(function(){}, 3000);"
