              "raw": "{\n  \"name\": \"Тестовый Пользователь\",\n  \"email\": \"test.user{{$timestamp}}@test.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/users",
              "host": ["{{baseUrl}}"],
