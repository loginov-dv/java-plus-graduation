    {
      "name": "Public: Просмотр комментариев",
      "item": [
        {
          "name": "Получить список комментариев (без параметров)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Ответ - массив\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "pm.test(\"Комментарии содержат нужные поля\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.length > 0) {",
                  "        var comment = jsonData[0];",
                  "        pm.expect(comment).to.have.property('id');",
                  "        pm.expect(comment).to.have.property('text');",
                  "        pm.expect(comment).to.have.property('userId');",
                  "        pm.expect(comment).to.have.property('eventId');",
                  "        pm.expect(comment).to.have.property('createdOn');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
